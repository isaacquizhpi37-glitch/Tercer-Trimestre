
#include <TFT_eSPI.h>   // Librería TFT_eSPI

TFT_eSPI tft = TFT_eSPI();

void setup() {
  tft.init();
  tft.setRotation(1);   // Pantalla horizontal
  tft.fillScreen(TFT_BLACK);

  // ====== CÍRCULOS ARRIBA ======
  tft.fillCircle(60, 40, 25, TFT_RED);     // Círculo rojo
  tft.fillCircle(120, 40, 25, TFT_GREEN);  // Círculo verde
  tft.fillCircle(180, 40, 25, TFT_BLUE);   // Círculo azul

  // ====== TEXTO ABAJO ======
  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.setTextSize(2);

  tft.setCursor(30, 100);
  tft.println("Isaaac quizhpi");

  tft.setCursor(30, 130);
  tft.println("Anthony barbecho");
}

void loop() {
  // Nada aqui
}
