<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Radar Inteligente</title>

  <style>
    body{
      margin:0;
      background:#000;
      overflow:hidden;
      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
      font-family:Arial, sans-serif;
    }

    canvas{
      background:#001100;
      border:3px solid #00ff00;
      border-radius:10px;
      box-shadow:0 0 20px #00ff00;
    }

    h1{
      position:absolute;
      top:20px;
      color:#00ff00;
      text-shadow:0 0 10px #00ff00;
    }
  </style>
</head>

<body>

<h1>RADAR INTELIGENTE</h1>

<canvas id="radar" width="700" height="700"></canvas>

<script>
const canvas = document.getElementById("radar");
const ctx = canvas.getContext("2d");

let angle = 0;
let direction = 1;

function drawRadar(){

  ctx.clearRect(0,0,canvas.width,canvas.height);

  const cx = canvas.width/2;
  const cy = canvas.height;

  // Fondo radar
  ctx.beginPath();
  ctx.arc(cx,cy,300,Math.PI,2*Math.PI);
  ctx.fillStyle = "#002200";
  ctx.fill();

  // Líneas del radar
  ctx.strokeStyle = "#00ff00";
  ctx.lineWidth = 2;

  for(let r=60; r<=300; r+=60){
    ctx.beginPath();
    ctx.arc(cx,cy,r,Math.PI,2*Math.PI);
    ctx.stroke();
  }

  // Líneas verticales
  for(let i=0;i<=180;i+=30){
    let rad = i*Math.PI/180;
    let x = cx + 300*Math.cos(rad);
    let y = cy - 300*Math.sin(rad);

    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(x,y);
    ctx.stroke();
  }

  // Línea barrido
  let rad = angle*Math.PI/180;

  let x = cx + 300*Math.cos(rad);
  let y = cy - 300*Math.sin(rad);

  ctx.beginPath();
  ctx.moveTo(cx,cy);
  ctx.lineTo(x,y);
  ctx.strokeStyle = "#00ff00";
  ctx.lineWidth = 4;
  ctx.stroke();

  // Brillo barrido
  for(let i=0;i<20;i++){
    let fadeAngle = (angle-i)*Math.PI/180;

    let fx = cx + 300*Math.cos(fadeAngle);
    let fy = cy - 300*Math.sin(fadeAngle);

    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(fx,fy);
    ctx.strokeStyle = `rgba(0,255,0,${0.05*i})`;
    ctx.lineWidth = 3;
    ctx.stroke();
  }

  // Objeto detectado
  let objAngle = 120*Math.PI/180;
  let objDist = 180;

  let ox = cx + objDist*Math.cos(objAngle);
  let oy = cy - objDist*Math.sin(objAngle);

  // Detecta cuando pasa el radar
  if(Math.abs(angle-120)<3){
    ctx.beginPath();
    ctx.arc(ox,oy,10,0,2*Math.PI);
    ctx.fillStyle="red";
    ctx.fill();

    ctx.font = "20px Arial";
    ctx.fillStyle = "white";
    ctx.fillText("OBJETO DETECTADO", 20,40);
  }

  // Movimiento del radar
  angle += direction;

  if(angle >= 180 || angle <= 0){
    direction *= -1;
  }

  requestAnimationFrame(drawRadar);
}

drawRadar();
</script>

</body>
</html>
